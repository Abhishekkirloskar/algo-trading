# Copy this file to ".env" and paste your Alpaca PAPER keys.
# Get them free at https://alpaca.markets (see README for steps).
# The .env file is gitignored so your keys never get committed.

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Optional: enables the AI analyst note in the dashboard (uses Claude).
# Get a key at https://console.anthropic.com . Leave unset to use the
# rule-based diagnosis instead — everything else works without it.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
